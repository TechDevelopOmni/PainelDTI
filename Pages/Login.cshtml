@page
@model PainelDTI.Pages.LoginModel
@{
    ViewData["Title"] = "Login";
}

<section class="login-box">
    <h1>Acesso ao Painel DTI</h1>
    <p>Senha para todos os usuários: <strong>123456</strong>.</p>
    <p>Exemplos: <strong>admin</strong>, <strong>comercial</strong>, <strong>operacoes</strong>, <strong>financeiro</strong>, <strong>juridico</strong>, <strong>marketing</strong>, <strong>admincomercial</strong>.</p>

    <form method="post">
        <label asp-for="Input.Usuario"></label>
        <input asp-for="Input.Usuario" />

        <label asp-for="Input.Senha"></label>
        <input asp-for="Input.Senha" type="password" />

        <button type="submit">Entrar</button>
    </form>

    @if (!string.IsNullOrWhiteSpace(Model.Erro))
    {
        <p class="error">@Model.Erro</p>
    }
</section>
